{
  "allow_process_stop": false,
  "require_execute_switch": true,
  "migration_policy": "manual_only",
  "human_report_language": "zh-CN",
  "min_report_size_gb": 1.0,
  "full_audit_drives": [
    "AUTO_FIXED_DRIVES"
  ],
  "closing_report_dir": "%USERPROFILE%\\Documents\\windows-c-disk-cleaner-reports",
  "c_drive_health_thresholds_gb": {
    "healthy": 50,
    "watch": 40,
    "urgent": 20
  },
  "browser_cache_dir_names": [
    "Cache",
    "Code Cache",
    "GPUCache",
    "DawnCache",
    "GrShaderCache",
    "ShaderCache",
    "Media Cache",
    "CacheStorage",
    "Crashpad",
    "component_crx_cache"
  ],
  "cache_scan_roots": [
    "%LOCALAPPDATA%\\Google\\Chrome\\User Data",
    "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data",
    "%APPDATA%\\Code",
    "%APPDATA%\\Antigravity"
  ],
  "auto_clear_paths": [
    "%LOCALAPPDATA%\\npm-cache",
    "%USERPROFILE%\\.bun\\install\\cache",
    "%USERPROFILE%\\.gemini\\antigravity\\browser_recordings",
    "%APPDATA%\\Code\\CachedExtensionVSIXs",
    "%APPDATA%\\Code\\CachedData",
    "%APPDATA%\\Code\\WebStorage",
    "%APPDATA%\\Antigravity\\CachedExtensionVSIXs",
    "%APPDATA%\\Antigravity\\CachedData",
    "%APPDATA%\\Antigravity\\WebStorage",
    "%APPDATA%\\rod\\browser",
    "%APPDATA%\\yoo_web_cache"
  ],
  "close_process_then_clear_paths": [
    "%LOCALAPPDATA%\\uv\\cache",
    "%LOCALAPPDATA%\\Google\\Chrome\\User Data",
    "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data"
  ],
  "suggest_only_roots": [
    "%USERPROFILE%\\xwechat_files",
    "%USERPROFILE%\\Documents\\WeChat Files",
    "%USERPROFILE%\\Desktop",
    "%USERPROFILE%\\Downloads",
    "%APPDATA%\\npm",
    "%LOCALAPPDATA%\\uv\\cache"
  ],
  "never_touch_roots": [
    "C:\\Windows",
    "C:\\Program Files",
    "C:\\Program Files (x86)",
    "C:\\pagefile.sys"
  ],
  "official_only_paths": [
    "C:\\Windows\\SoftwareDistribution",
    "C:\\$WINDOWS.~BT"
  ],
  "app_managed_paths": [
    "%APPDATA%\\npm",
    "C:\\Program Files\\Docker",
    "C:\\Program Files\\WSL",
    "%LOCALAPPDATA%\\Google\\Chrome\\User Data",
    "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data"
  ],
  "watch_for_two_weeks": [],
  "protected_user_data_hints": [
    "WeChat and messaging app chat data",
    "AI assistant app state (Claude, Codex, Gemini/Antigravity, etc.)",
    "Personal documents, photos, and project files",
    "SSH keys and Docker/WSL configuration",
    "App-managed data and virtual disks must not be moved or deleted automatically"
  ]
}
