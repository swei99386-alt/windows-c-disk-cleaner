  "watch_for_two_weeks": [
    {
      "name": "Docker Desktop data",
      "path": "E:\\Docker_Data\\DockerDesktopWSL\\disk\\docker_data.vhdx",
      "remove_rule": "Only recommend uninstall/removal after two consecutive weekly reports show no Docker service, process, WSL distro activity, or active project Docker usage."
    },
    {
      "name": "WSL Ubuntu",
      "path": "E:\\WSL\\Ubuntu\\ext4.vhdx",
      "remove_rule": "Do not delete directly; export/unregister WSL if the Linux environment is retired."
    }
  ],
  "protected_user_data_hints": [
    "WeChat and messaging app chat data",
    "AI assistant app state (Claude, Codex, etc.)",
    "Personal documents, photos, and project files",
    "SSH keys and Docker/WSL configuration"
  ]
