{
  "allow_process_stop": false,
  "human_report_language": "zh-CN",
  "min_report_size_gb": 1.0,
  "full_audit_drives": [
    "C:\\",
    "E:\\",
    "F:\\"
  ],
  "closing_report_dir": "E:\\disk-audit-reports",
  "c_drive_health_thresholds_gb": {
    "healthy": 50,
    "watch": 40,
    "urgent": 20
  },
  "browser_cache_dir_names": [
    "Cache",
    "Code Cache",
    "GPUCache",
    "DawnCache",
    "GrShaderCache",
    "ShaderCache",
    "Media Cache",
    "CacheStorage",
    "Crashpad",
    "component_crx_cache"
  ],
  "cache_scan_roots": [
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\Google\\Chrome\\User Data",
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\Microsoft\\Edge\\User Data",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Code",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Antigravity"
  ],
  "auto_clear_paths": [
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\npm-cache",
    "C:\\Users\\YOURUSERNAME\\.bun\\install\\cache",
    "C:\\Users\\YOURUSERNAME\\.gemini\\antigravity\\browser_recordings",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Code\\CachedExtensionVSIXs",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Code\\CachedData",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Code\\WebStorage",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Antigravity\\CachedExtensionVSIXs",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Antigravity\\CachedData",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\Antigravity\\WebStorage",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\rod\\browser",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\yoo_web_cache"
  ],
  "close_process_then_clear_paths": [
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\uv\\cache",
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\Google\\Chrome\\User Data",
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\Microsoft\\Edge\\User Data"
  ],
  "suggest_only_roots": [
    "C:\\Users\\YOURUSERNAME\\xwechat_files",
    "C:\\Users\\YOURUSERNAME\\Documents\\WeChat Files",
    "C:\\Users\\YOURUSERNAME\\Desktop",
    "C:\\Users\\YOURUSERNAME\\Downloads",
    "C:\\Users\\YOURUSERNAME\\AppData\\Roaming\\npm",
    "C:\\Users\\YOURUSERNAME\\AppData\\Local\\uv\\cache"
  ],
  "never_touch_roots": [
    "C:\\Windows",
    "C:\\Program Files",
    "C:\\Program Files (x86)",
